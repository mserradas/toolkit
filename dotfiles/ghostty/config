font-family = "JetBrainsMono Nerd Font Mono"
font-feature = calt
font-feature = liga
font-size = 14

background-opacity = 0.95
background-blur-radius = 20

window-padding-color = extend
window-step-resize = false
window-padding-balance = true

### Mac Alt Fix
macos-option-as-alt = right

keybind = alt+left=unbind
keybind = alt+right=unbind

# Split Management
keybind = alt+v=new_split:right
keybind = alt+d=new_split:down

# Resize Split
keybind = ctrl+shift+j=resize_split:up,10
keybind = ctrl+shift+k=resize_split:down,10
keybind = ctrl+shift+h=resize_split:left,10
keybind = ctrl+shift+l=resize_split:right,10

# Navigation
keybind = alt+k=goto_split:up
keybind = alt+j=goto_split:down
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right

# Miscellaneous
keybind = cmd+k=clear_screen
keybind = cmd+g=text:\x1bg

# Use it by writing 'vim' first and then the keybinding to open the file with vim
keybind = alt+s=write_screen_file:paste
keybind = shift+enter=text:\x1b\r

# Theme (Reemplaza las 16 líneas de paleta manual)
theme = Catppuccin Mocha

# Tus colores personalizados para el fondo y cursor
background = 0b0b11
foreground = f3f6f9
cursor-color = e0c15a
selection-background = 263356
selection-foreground = f3f6f9

# Tmux
command = /opt/homebrew/bin/fish -l -c 'tmux new-session -A -s work'

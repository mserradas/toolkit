{
  "name": "ms-agent-kit",
  "version": "0.1.0",
  "description": "Instalador portable y seguro para agentes, comandos y skills ms-*",
  "type": "module",
  "bin": {
    "ms-agent-kit": "dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.0",
  "license": "MIT"
}
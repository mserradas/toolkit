{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "ms-architect",
  "enabled_providers": [
    "openai"
  ],
  "permission": {
    "bash": {
      "env": "deny",
      "printenv*": "deny",
      "cat .env": "deny",
      "cat .env.local": "deny",
      "cat .env.*.local": "deny",
      "cat .env.development": "deny",
      "cat .env.production": "deny",
      "cat .env.staging": "deny",
      "cat .env.test": "deny",
      "cat */.env": "deny",
      "cat */.env.local": "deny",
      "cat */.env.*.local": "deny",
      "cat **/.env": "deny",
      "cat **/.env.local": "deny",
      "cat **/.env.*.local": "deny",
      "cat **/secrets/**": "deny",
      "cat **/.ssh/**": "deny",
      "cat **/.aws/credentials": "deny",
      "cat **/.config/gh/hosts.yml": "deny"
    },
    "read": {
      "**/.aws/credentials": "deny",
      "**/.config/gh/hosts.yml": "deny",
      "**/.credentials/**": "deny",
      "**/.docker/config.json": "deny",
      "**/.env": "deny",
      "**/.env.local": "deny",
      "**/.env.*.local": "deny",
      "**/.env.development": "deny",
      "**/.env.production": "deny",
      "**/.env.staging": "deny",
      "**/.env.test": "deny",
      "**/.kube/config": "deny",
      "**/.netrc": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.ssh/**": "deny",
      "**/Library/Keychains/**": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny"
    }
  },
  "instructions": [
    "./docs/agents-shared.md"
  ],
  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "@mohak34/opencode-notifier@0.2.8"
  ]
}

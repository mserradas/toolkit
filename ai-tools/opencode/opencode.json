{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5-fast",
  "default_agent": "ms-architect",
  "enabled_providers": ["openai"],
  "provider": {
    "openai": {
      "options": {
        "timeout": 180000,
        "chunkTimeout": 30000
      }
    }
  },
  "instructions": ["./docs/agents-shared.md"],
  "plugin": ["@warp-dot-dev/opencode-warp", "@mohak34/opencode-notifier@latest"]
}
